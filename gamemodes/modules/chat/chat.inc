#define TALK_ANIM_BASE_TIME     (500)
#define TALK_ANIM_PER_CHAR      (66)   
#define TALK_ANIM_MAX_TIME      (6000) 
#define TALK_DISTANCE   	    (30.0)
#define SHOUT_DISTANCE  	    (60.0)
#define LOW_DISTANCE    	    (5.0)
#define ACTION_DISTANCE 	    (30.0)
#define MEGAPHONE_DISTANCE      (70.0) 

#define ACTION_ME               (1)
#define ACTION_DO               (2)

public OnPlayerText(playerid, text[])
{
    if (!HasPlayerLogged(playerid)) {
        GameTextForPlayer(playerid, "~r~Voce nao esta logado!", 3000, 3);
        return 0;
    }

    new string[128];
    format(string, sizeof(string), "%.128s", text);
    TalkMessage(TALK_DISTANCE, playerid, "", string);

    return 0;
}

static TalkMessage(Float:dist, playerid, const prefix[], message[])
{
    new PlayerName[MAX_PLAYER_NAME+1];
	new Msg[256+1];
	new MsgWithName[256+1];
	
	if (!strlen(message)) return;

	if (IsPlayerConnected(playerid))
	{
		new Float:fPlayerX, Float:fPlayerY, Float:fPlayerZ;
		new Float:fPlayerToPlayerDist;
		new Float:fNormDistance;
		new ColorScale;
		new ColorValue;

        new duration = TALK_ANIM_BASE_TIME + (strlen(message) * TALK_ANIM_PER_CHAR);

        if (duration > TALK_ANIM_MAX_TIME) {
            duration = TALK_ANIM_MAX_TIME;
        }

        ApplyAnimation(
            playerid,
            "PED",
            "IDLE_CHAT",
            4.1,
            false,
            false,
            false,
            false,
            duration,
            SYNC_ALL
        );

		GetPlayerName(playerid, PlayerName, sizeof(PlayerName));
		if (strlen(prefix)) {
			format(Msg, sizeof(Msg), "%s %s", prefix, message);
		} else {
		    format(Msg, sizeof(Msg), "%s", message);
		}
		
		format(MsgWithName, sizeof(MsgWithName), "%s diz: %.64s", PlayerName, Msg);

        SetPlayerChatBubble(playerid, Msg, SPEECH_BUBBLE_COLOR, dist, duration);

		// Send to originating player
		SendClientMessage(playerid, LOCAL_TALK_COLOR, MsgWithName);

		if (strlen(Msg) > 64) {
			new string[64];
			format(string, sizeof(string), "...%s", Msg[64]);
			SendClientMessage(playerid, LOCAL_TALK_COLOR, string);
		}

		GetPlayerPos(playerid, fPlayerX, fPlayerY, fPlayerZ);

		foreach (new i : Player) {
		    if((i != playerid) && IsPlayerStreamedIn(playerid, i)) {
		        fPlayerToPlayerDist = GetPlayerDistanceFromPoint(i, fPlayerX, fPlayerY, fPlayerZ);
				if(fPlayerToPlayerDist < dist) { // receiving player is within the specified distance
					// get normalized distance to create a fade.
					fNormDistance = 1.0 - (fPlayerToPlayerDist / dist);
  					if(fNormDistance > 0.75) ColorScale = 220;
					else ColorScale = floatround(96.0 + (128.0 * fNormDistance));
					ColorValue = 0x000000FF | ColorScale << 24 | ColorScale << 16 | ColorScale << 8;
					SendClientMessage(i, ColorValue, MsgWithName);
					if (strlen(Msg) > 64) {
						new string[64];
						format(string, sizeof(string), "...%s", Msg[64]);
						SendClientMessage(i, LOCAL_TALK_COLOR, string);
					}
				}
			}
		}
	}
}

