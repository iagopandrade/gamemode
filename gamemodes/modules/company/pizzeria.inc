PizzeriaGantonInit()
{
    Company_Create(
        PIZZERIA,
        "Pizzaria",
        COMPANY_TYPE_RESTAURANT
    );

    Company_AddMapIcon(
        PIZZERIA,
        29,
        2104.9644, -1806.5123, 13.5547
    );

    Company_AddPoint(
        PIZZERIA,
        COMPANY_POINT_ENTRANCE,
        2104.9644,-1806.5123,13.5547, 129.3870,
        0.5,
        1239,
        1,
        0,
        0
    );

    Company_AddPoint(
        PIZZERIA,
        COMPANY_POINT_EXIT,
        372.5565, -131.3607, 1001.4922, 1.0,
        0.5,
        1239,
        1,
        5,
        0
    );

    return 1;
}

hook OnCompanyPoint@3(playerid, companyid, pointid)
{
    if (companyid != PIZZERIA) {
        return 1;
    }

    switch (Company_GetPointType(companyid, pointid))
    {
        case COMPANY_POINT_ENTRANCE:
        {
            Pizzeria_ShowEntranceDialog(playerid);
        }

        case COMPANY_POINT_EXIT:
        {
            Company_Exit(playerid, companyid, 0.0, 1.5, 0.0);
        }
    }

    return 1;
}

static enum {
    ENUMATOR_PIZZERIA_ENTER
};

Dialog:ENUMATOR_PIZZERIA_ENTER(playerid, response, listitem)
{
    if (!response) {
        return 1;
    }

    Company_Enter(playerid, PIZZERIA, 0.0, 1.5, 0.0);
    return 1;
}

Pizzeria_ShowEntranceDialog(playerid)
{
    if (Dialog_Opened(playerid)) {
        return 0;
    }

    new title[MAX_COMPANY_NAME];
    new name[MAX_COMPANY_NAME];

    Company_GetName(
        PIZZERIA,
        name
    );

    format(title, sizeof(title), "%s", name);

    Dialog_Show(playerid, ENUMATOR_PIZZERIA_ENTER,
        DIALOG_STYLE_MSGBOX,
        title,
        "Deseja entrar na pizzaria?",
        "Entrar",
        "Cancelar"
    );
    return 1;
}

